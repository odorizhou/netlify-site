## VPS publisher env (copy to /opt/kgsbot-stats/env)
#
# This publisher pulls stats from kgs-bot-monitor on localhost and pushes JSON into
# the private GitHub repo `odorizhou/kgsbot-stats-private`.

# Which bot to publish (matches the Netlify page input)
BOT_ID=gh204

# kgs-bot-monitor backend (local-only)
MONITOR_BASE_URL=http://127.0.0.1:4001
MONITOR_API_KEY=

# GitHub repo target for published JSON
REPO=odorizhou/kgsbot-stats-private
BRANCH=main

# GitHub token with repo Contents read+write permissions
GITHUB_TOKEN=

